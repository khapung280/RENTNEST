# Copy to .env and fill in values.

# Stripe — get keys from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development.
STRIPE_SECRET_KEY=
# Webhook signing secret from Stripe CLI or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=

# Public site URL (no trailing slash) — used for Stripe success/cancel redirects
FRONTEND_URL=http://localhost:5173

# Checkout currency: "usd" works with default US test accounts (NPR total converted for display).
# Use "npr" if your Stripe account supports NPR settlement.
STRIPE_CHECKOUT_CURRENCY=usd

# When STRIPE_CHECKOUT_CURRENCY=usd, NPR total is converted using this rate (tune as needed).
NPR_TO_USD=0.0075

# Khalti (https://khalti.com) — test: https://dev.khalti.com
KHALTI_SECRET_KEY=
# Omit or set to "live" for production API host
# KHALTI_MODE=live

# eSewa (optional — server signing not implemented until keys + v2 flow added)
# ESEWA_MERCHANT_ID=
# ESEWA_SECRET_KEY=
