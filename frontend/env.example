# ============================================
# RentNest Frontend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Vite only exposes variables prefixed with VITE_
# NEVER commit .env to git.

# Backend API base URL (without /api)
# Your Render web service URL (no trailing slash). Must match the API you deployed.
VITE_API_URL=https://rentnest-jca7.onrender.com

# Example for other environments:
# VITE_API_URL=https://your-backend-url.com
